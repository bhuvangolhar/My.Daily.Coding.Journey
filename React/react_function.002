
// (React function : User input)

import { useState } from "react";
function App() {
  const [name, setName] = useState("");
  return (
    <>
      <input
        type="text"
        placeholder="Enter your name"
        onChange={(e) => setName(e.target.value)}
      />
      <p>{name}</p>
    </>
  );
}
export default App;
