
// (React function : Comparison of strings)

import { useState } from "react";
function App() {
  const [value, setValue] = useState("");
  return (
    <>
      <input
        type="text"
        placeholder="Type your name"
        onChange={(e) => setValue(e.target.value)}
      />
      <p>{value === "admin" ? "You're Admin now" : "Not an Admin"}</p>
    </>
  );
}
export default App;
