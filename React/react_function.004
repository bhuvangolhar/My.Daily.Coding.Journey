
// (React function : String length)

import { useState } from "react";
function App() {
  const [text, setText] = useState("");
  return (
    <>
      <input
        type="text"
        placeholder="Enter text"
        onChange={(e) => setText(e.target.value)}
      />
      <p>Length: {text.length}</p>
    </>
  );
}
export default App;
