
<!-- (HTML file : String concatenation) -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>String concatenation</title>
    <link rel="stylesheet" href="string_concatenation.css">
</head>
<body>
    <h2 id="output"></h2>
    <script src="string_concatenation.js"></script> 
</body>
</html>


/* (CSS file : String concatenation) */

body
{
    background-color: brown;
    font-family: Arial, Helvetica, sans-serif;
    font-size: medium;
}


/* (JavaScript file : String concatenation) */

let firstName = prompt("Enter first name:");
let lastName = prompt("Enter last name:");
document.getElementById("output").innerText = firstName + " " + lastName;
