
<!-- (HTML file : Division) -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Division</title>
    <link rel="stylesheet" href="division.css">
</head>
<body>
    <p id="result"></p>
    <script src="division.js"></script> 
</body>
</html>


/* (CSS file : Division) */

body
{
    background-color: azure
}


/* (JavaScript file : Division) */

let a = Number(prompt("Enter the first integer:"));
let b = Number(prompt("Enter the second integer:"));
let quotient = a / b;
document.getElementById("result").innerText = quotient;
