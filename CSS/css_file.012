
<!-- (HTML file : Text alignment in div) -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Text alignment in div</title>
    <link rel="stylesheet" href="text_alignment_in_div.css">
</head>
<body>
    <div>
        Java is a high-level programming language 
        invented in 1991 by James Gosling at Sun Microsystems.
    </div>
</body>
</html>


/* (CSS file : Text alignment in div) */

body 
{
    background-color: wheat;
    font-family:'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif
}
div
{
    text-align: center;
    color: black;
    font-size: 18px;
    height: 30px;
    width: 1520px;
    background-color: red;
}
