
<!-- (HTML file : Outline style in div) -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Outline style in div</title>
    <link rel="stylesheet" href="outline_style_in_div.css">
</head>
<body>
    <div>
        C is a general-purpose programming language 
        invented in 1972 by Dennis Ritchie at Bell Labs.
    </div>
</body>
</html>


/* (CSS file : Outline style in div) */

body 
{
    background-color: wheat;
    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
}
div
{
    text-align: right;
    margin-top: 225px;
    margin-right: 225px;
    margin-bottom: 225px;
    margin-left: 225px;
    padding-top: 110px;
    padding-right: 110px;
    padding-bottom: 110px;
    padding-left: 110px;
    outline-width: 7px;
    outline-style: solid;
    color: black;
    font-size: 18px;
    height: 30px;
    width: 980px;
    background-color: purple;
}
